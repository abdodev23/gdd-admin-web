# Backend API URL — Phase 1 dev default
VITE_API_URL=http://localhost:5000/api

# Firebase Client Config — copy these EXACT values from gdd-user-web/.env.
# Admin and user share the same Firebase project. Don't create a new project
# or web app entry. Role-based access is enforced by the backend.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
